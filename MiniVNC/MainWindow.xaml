<Window x:Class="MiniVNC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MiniVNC - Mac远程控制"
        Width="520"
        Height="452"
        MinWidth="520"
        MinHeight="452"
        MaxWidth="520"
        MaxHeight="452"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        FontFamily="Segoe UI"
        FontSize="12">

    <Window.Resources>
        <!-- 通用按钮样式 -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主要操作按钮样式（蓝色强调） -->
        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
        </Style>

        <!-- 连接按钮样式（绿色） -->
        <Style x:Key="ConnectButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#107C10"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#107C10"/>
        </Style>

        <!-- 列表项样式 -->
        <Style x:Key="ConnectionListStyle" TargetType="ListView">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- 列表项容器样式 -->
        <Style x:Key="ConnectionListItemStyle" TargetType="ListViewItem">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#094771"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#CCCCCC"/>
            <Setter Property="SelectionBrush" Value="#0078D4"/>
        </Style>

        <!-- 状态栏文本样式 -->
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#808080"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Background="#2D2D30"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnAdd"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="BtnAdd_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="新增"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnEdit"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="BtnEdit_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE70F;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="编辑"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnDelete"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="BtnDelete_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="删除"/>
                    </StackPanel>
                </Button>
                <Border Width="1"
                        Background="#3E3E42"
                        Margin="6,0"/>
                <Button x:Name="BtnConnect"
                        Style="{StaticResource ConnectButtonStyle}"
                        Click="BtnConnect_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="连接"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- 连接列表 -->
        <Border Grid.Row="1"
                Background="#1E1E1E"
                Padding="8">
            <ListView x:Name="LvConnections"
                      Style="{StaticResource ConnectionListStyle}"
                      ItemContainerStyle="{StaticResource ConnectionListItemStyle}"
                      MouseDoubleClick="ListView_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="#2D2D30"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                                <Setter Property="BorderBrush" Value="#3E3E42"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GridViewColumnHeader">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Header="名称"
                                        Width="140"
                                        DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="主机"
                                        Width="180"
                                        DisplayMemberBinding="{Binding Host}"/>
                        <GridViewColumn Header="端口"
                                        Width="60"
                                        DisplayMemberBinding="{Binding Port}"/>
                        <GridViewColumn Header="备注"
                                        Width="100"
                                        DisplayMemberBinding="{Binding Description}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- 快速连接区域 -->
        <Border Grid.Row="2"
                Background="#2D2D30"
                BorderBrush="#3E3E42"
                BorderThickness="0,1,0,0"
                Padding="8,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="86"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 第一行：主机 + 端口 -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="主机:"
                           Foreground="#808080"
                           VerticalAlignment="Center"
                           Margin="0,0,8,4"/>
                <TextBox x:Name="TbQuickHost"
                         Grid.Row="0" Grid.Column="1"
                         Style="{StaticResource DarkTextBoxStyle}"
                         VerticalAlignment="Center"
                         Margin="0,0,0,4"
                         ToolTip="输入IP地址或主机名"/>
                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="端口:"
                           Foreground="#808080"
                           VerticalAlignment="Center"
                           Margin="8,0,4,4"/>
                <TextBox x:Name="TbQuickPort"
                         Grid.Row="0" Grid.Column="3"
                         Style="{StaticResource DarkTextBoxStyle}"
                         Text="5900"
                         VerticalAlignment="Center"
                         Margin="0,0,0,4"/>

                <!-- 第二行：用户名 + 密码 + 连接 -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="用户名:"
                           Foreground="#808080"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox x:Name="TbQuickUser"
                         Grid.Row="1" Grid.Column="1"
                         Style="{StaticResource DarkTextBoxStyle}"
                         VerticalAlignment="Center"
                         ToolTip="Mac 账户用户名（屏幕共享 Apple 认证需要；标准 VNC 密码可留空）"/>
                <TextBlock Grid.Row="1" Grid.Column="2"
                           Text="密码:"
                           Foreground="#808080"
                           VerticalAlignment="Center"
                           Margin="8,0,4,0"/>
                <PasswordBox x:Name="PbQuickPassword"
                             Grid.Row="1" Grid.Column="3"
                             VerticalAlignment="Center"/>
                <Button x:Name="BtnQuickConnect"
                        Grid.Row="0" Grid.Column="4" Grid.RowSpan="2"
                        Style="{StaticResource ConnectButtonStyle}"
                        Margin="8,0,0,0"
                        Click="BtnQuickConnect_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="连接"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- 底部状态栏 -->
        <Border Grid.Row="3"
                Background="#0078D4"
                Padding="8,4">
            <Grid>
                <TextBlock x:Name="TbStatus"
                           Style="{StaticResource StatusTextStyle}"
                           Foreground="#FFFFFF"
                           Text="就绪 - 请选择连接或输入主机地址"/>
            </Grid>
        </Border>
    </Grid>
</Window>
